generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String
  price        Float
  affiliateUrl String
  category     String
  clickCount   Int      @default(0)
  createdAt    DateTime @default(now())
}
